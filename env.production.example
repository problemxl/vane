# ── Production environment variables ─────────────────────────────────
# Copy: cp env.production.example .env.production
# These are IDENTITY credentials only — no application secrets.
# All app secrets (keys, tokens) live exclusively in Infisical.
#
# The .env file is loaded by pydantic-settings before Infisical
# injection, so any value you set here takes precedence over Infisical.
# Leave secret fields empty (or absent) to pull them from Infisical.

# ── App ─────────────────────────────────────────────────────────────
APP_NAME=Vane
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── Database ─────────────────────────────────────────────────────────
# DATABASE_URL — store in Infisical, not here. It contains the
# database password, which should never appear in environment files.
# For local dev without Infisical, set DATABASE_URL in .env directly.
# Example (DO NOT put real passwords here):
#   postgresql+asyncpg://vane:PASSWORD@db:5432/vane

# ── Infisical bootstrap (identity credentials) ──────────────────────
# Machine identity created in Infisical: Settings → Machine Identities
# These authenticate the SDK to fetch real secrets at startup.
INFISICAL_ENABLED=true
INFISICAL_HOST=https://app.infisical.com
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENV=production
INFISICAL_PATH=/

# ── Trading ─────────────────────────────────────────────────────────
# Start in PAPER mode. Validate P&L before switching to live.
TRADING_ENABLED=false
TRADING_MODE=paper

# ── Scheduling ──────────────────────────────────────────────────────
SCAN_INTERVAL_MINUTES=15
FORECAST_FETCH_INTERVAL_MINUTES=60

# ── Security ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS
# ALLOWED_ORIGINS=https://your-dashboard.com,https://admin.example.com
# Comma-separated list of allowed hostnames for Host header validation
# ALLOWED_HOSTS=vane.example.com,api.example.com
# Sentry DSN for error monitoring (optional)
# SENTRY_DSN=https://...@sentry.io/...
