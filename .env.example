# App
APP_NAME=Vane
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database (SQLite default; use postgresql+asyncpg:// for Postgres)
DATABASE_URL=sqlite+aiosqlite:///./data/vane.db

# ── Infisical (secrets backend) ─────────────────────────────────────
# Bootstrap credentials authenticate the SDK to fetch real secrets.
# These IDENTITY credentials are safe to set in .env; the actual secrets
# (private keys, tokens, etc.) live ONLY in Infisical, never in .env.
#
# Set INFISICAL_ENABLED=true to activate Infisical fetching at startup.
# If false (default), all secrets must be in .env or the shell environment.
#
# Alternative: skip the SDK and use `infisical run` CLI instead:
#   infisical run --env dev -- python -m vane
# This injects secrets as env vars before the process starts — no code
# changes needed.
INFISICAL_ENABLED=false
INFISICAL_HOST=https://app.infisical.com
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_TOKEN=
INFISICAL_PROJECT_ID=
INFISICAL_ENV=dev
INFISICAL_PATH=/

# Polymarket (required for live trading; optional for read-only)
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_WALLET_ADDRESS=0x...
# CLOB API credentials (generated via create_api_key script)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_PASSPHRASE=

# Trading
TRADING_ENABLED=false
TRADING_MODE=paper
BANKROLL_USD=1000.0
MAX_POSITION_SIZE_USD=50.0
MAX_TOTAL_EXPOSURE_USD=400.0
MAX_DAILY_LOSS_USD=100.0
MIN_EDGE_THRESHOLD=0.10
KELLY_FRACTION=0.25
MAX_TRADES_PER_DAY=10
MIN_POSITION_SIZE_USD=5.0

# Weather
OPENMETEO_URL=https://api.open-meteo.com/v1
NOAA_ASOS_URL=https://mesonet.agron.iastate.edu/geojson
FORECAST_T_DF=4.0

# Telegram (optional — disables Telegram if not set)
TELEGRAM_BOT_TOKEN=...
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook
TELEGRAM_WEBHOOK_SECRET=...
TELEGRAM_ADMIN_CHAT_IDS=[]

# Scheduling
SCAN_INTERVAL_MINUTES=15
FORECAST_FETCH_INTERVAL_MINUTES=60

# ── Using Infisical (choose one approach) ────────────────────────────
#
# Approach 1 — infisical run CLI (simplest, zero code changes):
#   $ infisical run --env dev -- python -m vane
#   The CLI injects all secrets as env vars before the process starts.
#   No SDK needed, no INFISICAL_* bootstrap vars needed.
#
# Approach 2 — SDK at startup (for containers / programmatic):
#   $ INFISICAL_ENABLED=true python -m vane
#   The SDK fetches secrets at import time and injects them as env vars.
#   Requires INFISICAL_CLIENT_ID, INFISICAL_CLIENT_SECRET,
#   and INFISICAL_PROJECT_ID in the actual environment (not .env).
